<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">

    <!-- App -->
    <s:String x:Key="App_Title">PdfKit - PDF 工具箱</s:String>
    <s:String x:Key="App_Subtitle">PDF 工具箱</s:String>

    <!-- Sidebar groups -->
    <s:String x:Key="Nav_Organize">整理</s:String>
    <s:String x:Key="Nav_Enhance">增強</s:String>
    <s:String x:Key="Nav_Document">文件</s:String>

    <!-- Nav items -->
    <s:String x:Key="Nav_Extract">擷取頁面</s:String>
    <s:String x:Key="Nav_Split">分割 PDF</s:String>
    <s:String x:Key="Nav_Merge">合併文件</s:String>
    <s:String x:Key="Nav_Organize_Pages">整理頁面</s:String>
    <s:String x:Key="Nav_Rotate">旋轉頁面</s:String>
    <s:String x:Key="Nav_Watermark">文字浮水印</s:String>
    <s:String x:Key="Nav_Metadata">PDF 中繼資料</s:String>
    <s:String x:Key="Nav_Security">PDF 安全性</s:String>

    <!-- Language switcher -->
    <s:String x:Key="Lang_Label">語言</s:String>
    <s:String x:Key="Lang_EN">English</s:String>
    <s:String x:Key="Lang_ZH_CN">简体中文</s:String>
    <s:String x:Key="Lang_ZH_TW">繁體中文</s:String>

    <!-- Common -->
    <s:String x:Key="Btn_Browse">瀏覽</s:String>
    <s:String x:Key="Btn_Close">關閉</s:String>
    <s:String x:Key="Lbl_SourcePdf">來源 PDF 檔案</s:String>
    <s:String x:Key="Lbl_OutputFile">輸出檔案</s:String>
    <s:String x:Key="Lbl_PageRange">頁面範圍</s:String>
    <s:String x:Key="Hint_BrowseSource">點擊瀏覽以選擇 PDF 檔案...</s:String>
    <s:String x:Key="Hint_BrowseOutput">點擊瀏覽以選擇儲存位置...</s:String>

    <!-- Extract -->
    <s:String x:Key="Extract_Title">擷取頁面</s:String>
    <s:String x:Key="Extract_Subtitle">從 PDF 擷取所選頁面並儲存為新檔案。</s:String>
    <s:String x:Key="Extract_PageRangeHint">支援單頁及範圍，例如：1, 3, 5-8, 10-12</s:String>
    <s:String x:Key="Extract_PageRangeTip">範例：1, 3, 5-8, 10</s:String>
    <s:String x:Key="Extract_Btn">擷取頁面</s:String>

    <!-- Split -->
    <s:String x:Key="Split_Title">分割 PDF</s:String>
    <s:String x:Key="Split_Subtitle">依頁數或自訂頁面範圍將 PDF 分割為多個檔案。</s:String>
    <s:String x:Key="Split_TabCount">依頁數分割</s:String>
    <s:String x:Key="Split_TabRanges">依頁面範圍分割</s:String>
    <s:String x:Key="Split_PagesPerFile">每個檔案頁數</s:String>
    <s:String x:Key="Split_PagesPerFileTip">每個分割檔案的頁數</s:String>
    <s:String x:Key="Split_PagesPerFileHint">例如：1 = 每頁單獨分割，3 = 每 3 頁為一組</s:String>
    <s:String x:Key="Split_PageRanges">頁面範圍</s:String>
    <s:String x:Key="Split_PageRangesTip">以分號分隔每個輸出檔案</s:String>
    <s:String x:Key="Split_PageRangesHint">每個分號分隔的群組產生一個檔案  |  例如：1-5 ; 6, 8-10 ; 11-15</s:String>
    <s:String x:Key="Split_OutputFolder">輸出資料夾</s:String>
    <s:String x:Key="Split_BrowseFolder">點擊瀏覽以選擇資料夾...</s:String>
    <s:String x:Key="Split_Prefix">檔案名稱前綴</s:String>
    <s:String x:Key="Split_PrefixTip">所有輸出檔案的檔案名稱前綴</s:String>
    <s:String x:Key="Split_Btn">分割 PDF</s:String>

    <!-- Merge -->
    <s:String x:Key="Merge_Title">合併文件</s:String>
    <s:String x:Key="Merge_Subtitle">依順序將多個 PDF 檔案合併為一個文件。</s:String>
    <s:String x:Key="Merge_FileList">PDF 檔案清單</s:String>
    <s:String x:Key="Merge_AddFiles">+ 新增檔案</s:String>
    <s:String x:Key="Merge_Clear">清空</s:String>
    <s:String x:Key="Merge_Up">上移</s:String>
    <s:String x:Key="Merge_Down">下移</s:String>
    <s:String x:Key="Merge_Remove">移除</s:String>
    <s:String x:Key="Merge_EmptyTitle">尚無檔案</s:String>
    <s:String x:Key="Merge_EmptyHint">點擊「新增檔案」或將 PDF 拖曳至此</s:String>
    <s:String x:Key="Merge_Btn">合併 PDF</s:String>

    <!-- Rotate -->
    <s:String x:Key="Rotate_Title">旋轉頁面</s:String>
    <s:String x:Key="Rotate_Subtitle">旋轉所選 PDF 頁面並儲存為新檔案。</s:String>
    <s:String x:Key="Rotate_AllPages">旋轉所有頁面</s:String>
    <s:String x:Key="Rotate_PageRangeHint">支援單頁及範圍，例如：1, 3, 5-8, 10-12</s:String>
    <s:String x:Key="Rotate_PageRangeTip">範例：1, 3, 5-8</s:String>
    <s:String x:Key="Rotate_Angle">旋轉角度</s:String>
    <s:String x:Key="Rotate_CW90">順時針 90°</s:String>
    <s:String x:Key="Rotate_180">180°</s:String>
    <s:String x:Key="Rotate_CCW90">逆時針 90°</s:String>
    <s:String x:Key="Rotate_Btn">旋轉頁面</s:String>

    <!-- Organize -->
    <s:String x:Key="Organize_Title">整理頁面</s:String>
    <s:String x:Key="Organize_Subtitle">刪除、重新排列或插入 PDF 文件中的頁面。</s:String>
    <s:String x:Key="Organize_PageList">頁面清單</s:String>
    <s:String x:Key="Organize_MoveUp">&#x2191;  上移</s:String>
    <s:String x:Key="Organize_MoveDown">&#x2193;  下移</s:String>
    <s:String x:Key="Organize_Delete">&#x2715;  刪除</s:String>
    <s:String x:Key="Organize_Insert">&#x2295;  從 PDF 插入...</s:String>
    <s:String x:Key="Organize_EmptyTitle">未載入頁面</s:String>
    <s:String x:Key="Organize_EmptyHint">開啟來源 PDF 以開始整理</s:String>
    <s:String x:Key="Organize_InsertTitle">從 PDF 插入頁面</s:String>
    <s:String x:Key="Organize_InsertSource">來源 PDF</s:String>
    <s:String x:Key="Organize_InsertSourceHint">選擇要插入的 PDF 檔案...</s:String>
    <s:String x:Key="Organize_InsertPages">頁面  (留空 = 全部)</s:String>
    <s:String x:Key="Organize_InsertPagesTip">範例：1, 3, 5-8 — 留空代表全部頁面</s:String>
    <s:String x:Key="Organize_InsertPosition">插入至第幾頁之後</s:String>
    <s:String x:Key="Organize_InsertPositionTip">0 = 插入至開頭，留空 = 附加至末尾</s:String>
    <s:String x:Key="Organize_InsertBtn">+ 新增頁面至清單</s:String>
    <s:String x:Key="Organize_Btn">儲存文件</s:String>

    <!-- Watermark -->
    <s:String x:Key="Wm_Title">文字浮水印</s:String>
    <s:String x:Key="Wm_Subtitle">在所有頁面或指定頁面範圍上加入文字浮水印。</s:String>
    <s:String x:Key="Wm_Text">浮水印文字</s:String>
    <s:String x:Key="Wm_Bold">粗體</s:String>
    <s:String x:Key="Wm_FontSize">字型大小 (pt)</s:String>
    <s:String x:Key="Wm_FontSizeTip">建議：40-120</s:String>
    <s:String x:Key="Wm_Opacity">透明度 %</s:String>
    <s:String x:Key="Wm_Color">顏色</s:String>
    <s:String x:Key="Wm_Position">位置</s:String>
    <s:String x:Key="Wm_Rotation">旋轉</s:String>
    <s:String x:Key="Wm_RotN45">-45°  (斜角)</s:String>
    <s:String x:Key="Wm_Rot0">0°  (水平)</s:String>
    <s:String x:Key="Wm_Rot45">45°</s:String>
    <s:String x:Key="Wm_Rot90">90°  (垂直)</s:String>
    <s:String x:Key="Wm_AllPages">套用至所有頁面</s:String>
    <s:String x:Key="Wm_PageRangeHint">單頁或範圍，例如：1, 3, 5-8, 10-12</s:String>
    <s:String x:Key="Wm_PageRangeTip">範例：1, 3, 5-8</s:String>
    <s:String x:Key="Wm_Btn">套用浮水印</s:String>

    <!-- Security -->
    <s:String x:Key="Sec_Title">PDF 安全性</s:String>
    <s:String x:Key="Sec_Subtitle">為 PDF 新增密碼保護，或移除現有密碼。</s:String>
    <s:String x:Key="Sec_TabEncrypt">加密 PDF</s:String>
    <s:String x:Key="Sec_TabRemove">移除密碼</s:String>
    <s:String x:Key="Sec_CurrentPwd">目前密碼  (未加密請留空)</s:String>
    <s:String x:Key="Sec_UserPwd">使用者密碼  (選填)</s:String>
    <s:String x:Key="Sec_UserPwdHint">設定後需要此密碼才能開啟文件。</s:String>
    <s:String x:Key="Sec_ConfirmPwd">確認使用者密碼</s:String>
    <s:String x:Key="Sec_OwnerPwd">擁有者密碼  (選填)</s:String>
    <s:String x:Key="Sec_OwnerPwdHint">設定後可限制編輯、複製、列印權限。</s:String>
    <s:String x:Key="Sec_PwdAtLeastOne">使用者密碼和擁有者密碼至少需要設定一項。</s:String>
    <s:String x:Key="Sec_Permissions">權限  (以使用者密碼開啟時生效)</s:String>
    <s:String x:Key="Sec_AllowPrint">允許列印</s:String>
    <s:String x:Key="Sec_AllowCopy">允許複製文字</s:String>
    <s:String x:Key="Sec_AllowModify">允許修改</s:String>
    <s:String x:Key="Sec_EncBtn">加密 PDF</s:String>
    <s:String x:Key="Sec_RemTitle">加密的 PDF 檔案</s:String>
    <s:String x:Key="Sec_RemSourceHint">點擊瀏覽以選擇加密的 PDF...</s:String>
    <s:String x:Key="Sec_RemCurrentPwd">目前密碼</s:String>
    <s:String x:Key="Sec_RemCurrentPwdHint">輸入使用者密碼或擁有者密碼以解鎖文件。</s:String>
    <s:String x:Key="Sec_RemBtn">移除密碼</s:String>

    <!-- Metadata -->
    <s:String x:Key="Meta_Title">PDF 中繼資料</s:String>
    <s:String x:Key="Meta_Subtitle">檢視並編輯 PDF 檔案中儲存的文件屬性。</s:String>
    <s:String x:Key="Meta_Load">載入中繼資料</s:String>
    <s:String x:Key="Meta_FieldTitle">標題</s:String>
    <s:String x:Key="Meta_Subject">主旨</s:String>
    <s:String x:Key="Meta_Creator">建立程式</s:String>
    <s:String x:Key="Meta_Author">作者</s:String>
    <s:String x:Key="Meta_Keywords">關鍵字</s:String>
    <s:String x:Key="Meta_ReadOnly">文件資訊  (唯讀)</s:String>
    <s:String x:Key="Meta_Producer">產生工具</s:String>
    <s:String x:Key="Meta_CreationDate">建立日期</s:String>
    <s:String x:Key="Meta_Btn">儲存中繼資料</s:String>

    <!-- Runtime strings -->
    <s:String x:Key="Rt_PagesDetected">已偵測到 {0} 頁</s:String>
    <s:String x:Key="Rt_PagesLoaded">已載入 {0} 頁</s:String>
    <s:String x:Key="Rt_UnableToRead">無法讀取頁數</s:String>
    <s:String x:Key="Rt_PasswordProtected">已加密 — 請在下方輸入目前密碼</s:String>
    <s:String x:Key="Rt_EnterPwdToRemove">請在下方輸入密碼，然後點擊「移除密碼」。</s:String>
    <s:String x:Key="Rt_ClickLoadMeta">點擊「載入中繼資料」以讀取文件屬性。</s:String>

    <s:String x:Key="Err_NoSourcePdf">請先選擇有效的來源 PDF 檔案。</s:String>
    <s:String x:Key="Err_NoPageRange">請輸入頁碼。</s:String>
    <s:String x:Key="Err_NoOutput">請選擇輸出檔案路徑。</s:String>
    <s:String x:Key="Err_NoOutputFolder">請選擇輸出資料夾。</s:String>
    <s:String x:Key="Err_NoPrefix">請輸入檔案名稱前綴。</s:String>
    <s:String x:Key="Err_NoPages">清單中沒有頁面，請先載入來源 PDF。</s:String>
    <s:String x:Key="Err_NoInsertSource">請選擇有效的要插入的 PDF 檔案。</s:String>
    <s:String x:Key="Err_EnterPagesOrAll">請輸入頁碼或啟用「旋轉所有頁面」。</s:String>
    <s:String x:Key="Err_EnterPagesOrAllWm">請輸入頁碼或啟用「套用至所有頁面」。</s:String>
    <s:String x:Key="Err_WmTextEmpty">浮水印文字不能為空。</s:String>
    <s:String x:Key="Err_NoPagesPerFile">每個檔案的頁數必須是大於等於 1 的整數。</s:String>
    <s:String x:Key="Err_NoRanges">請輸入頁面範圍。</s:String>
    <s:String x:Key="Err_UserPwdRequired">加密時必須設定使用者密碼。</s:String>
    <s:String x:Key="Err_NoPwdProvided">請至少提供一項密碼（使用者密碼或擁有者密碼）。</s:String>
    <s:String x:Key="Err_PwdMismatch">兩次輸入的密碼不一致，請重新確認。</s:String>

    <s:String x:Key="Ok_Extracted">已擷取 {0} 頁 → {1}</s:String>
    <s:String x:Key="Ok_Merged">已合併 {0} 個檔案（共 {1} 頁）→ {2}</s:String>
    <s:String x:Key="Ok_Rotated">已旋轉 {0} 頁（{1}°）→ {2}</s:String>
    <s:String x:Key="Ok_Saved">已儲存 {0} 頁 → {1}</s:String>
    <s:String x:Key="Ok_Encrypted">PDF 加密成功 → {0}</s:String>
    <s:String x:Key="Ok_PwdRemoved">密碼已移除 → {0}</s:String>
    <s:String x:Key="Ok_WatermarkApplied">浮水印已套用（{0} 頁）→ {1}</s:String>
    <s:String x:Key="Ok_MetaSaved">中繼資料已儲存 → {0}</s:String>
    <s:String x:Key="Ok_Split">已分割為 {0} 個檔案 → {1}</s:String>
    <s:String x:Key="Err_RemovePwdFailed">操作失敗：{0} — 請確認密碼是否正確。</s:String>

    <!-- Dialog titles -->
    <s:String x:Key="Dlg_SelectPdf">選擇 PDF 檔案</s:String>
    <s:String x:Key="Dlg_SelectPdfs">選擇 PDF 檔案</s:String>
    <s:String x:Key="Dlg_SelectFolder">選擇分割檔案的輸出資料夾</s:String>
    <s:String x:Key="Dlg_SavePdf">儲存 PDF 檔案</s:String>

</ResourceDictionary>

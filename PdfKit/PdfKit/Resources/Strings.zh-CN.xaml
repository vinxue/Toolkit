<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">

    <!-- App -->
    <s:String x:Key="App_Title">PdfKit - PDF 工具箱</s:String>
    <s:String x:Key="App_Subtitle">PDF 工具箱</s:String>

    <!-- Sidebar groups -->
    <s:String x:Key="Nav_Organize">整理</s:String>
    <s:String x:Key="Nav_Enhance">增强</s:String>
    <s:String x:Key="Nav_Document">文档</s:String>

    <!-- Nav items -->
    <s:String x:Key="Nav_Extract">提取页面</s:String>
    <s:String x:Key="Nav_Split">拆分 PDF</s:String>
    <s:String x:Key="Nav_Merge">合并文档</s:String>
    <s:String x:Key="Nav_Organize_Pages">整理页面</s:String>
    <s:String x:Key="Nav_Rotate">旋转页面</s:String>
    <s:String x:Key="Nav_Watermark">文字水印</s:String>
    <s:String x:Key="Nav_Metadata">PDF 元数据</s:String>
    <s:String x:Key="Nav_Security">PDF 安全</s:String>

    <!-- Language switcher -->
    <s:String x:Key="Lang_Label">语言</s:String>
    <s:String x:Key="Lang_EN">English</s:String>
    <s:String x:Key="Lang_ZH_CN">简体中文</s:String>
    <s:String x:Key="Lang_ZH_TW">繁體中文</s:String>

    <!-- Common -->
    <s:String x:Key="Btn_Browse">浏览</s:String>
    <s:String x:Key="Btn_Close">关闭</s:String>
    <s:String x:Key="Lbl_SourcePdf">源 PDF 文件</s:String>
    <s:String x:Key="Lbl_OutputFile">输出文件</s:String>
    <s:String x:Key="Lbl_PageRange">页面范围</s:String>
    <s:String x:Key="Hint_BrowseSource">点击浏览以选择 PDF 文件...</s:String>
    <s:String x:Key="Hint_BrowseOutput">点击浏览以选择保存位置...</s:String>

    <!-- Extract -->
    <s:String x:Key="Extract_Title">提取页面</s:String>
    <s:String x:Key="Extract_Subtitle">从 PDF 中提取所选页面并保存为新文件。</s:String>
    <s:String x:Key="Extract_PageRangeHint">支持单页和范围，例如：1, 3, 5-8, 10-12</s:String>
    <s:String x:Key="Extract_PageRangeTip">示例：1, 3, 5-8, 10</s:String>
    <s:String x:Key="Extract_Btn">提取页面</s:String>

    <!-- Split -->
    <s:String x:Key="Split_Title">拆分 PDF</s:String>
    <s:String x:Key="Split_Subtitle">按页数或自定义页面范围将 PDF 拆分为多个文件。</s:String>
    <s:String x:Key="Split_TabCount">按页数拆分</s:String>
    <s:String x:Key="Split_TabRanges">按页面范围拆分</s:String>
    <s:String x:Key="Split_PagesPerFile">每个文件页数</s:String>
    <s:String x:Key="Split_PagesPerFileTip">每个拆分文件的页数</s:String>
    <s:String x:Key="Split_PagesPerFileHint">例如：1 = 每页单独拆分，3 = 每 3 页为一组</s:String>
    <s:String x:Key="Split_PageRanges">页面范围</s:String>
    <s:String x:Key="Split_PageRangesTip">用分号分隔每个输出文件</s:String>
    <s:String x:Key="Split_PageRangesHint">每个分号分隔的组生成一个文件  |  例如：1-5 ; 6, 8-10 ; 11-15</s:String>
    <s:String x:Key="Split_OutputFolder">输出文件夹</s:String>
    <s:String x:Key="Split_BrowseFolder">点击浏览以选择文件夹...</s:String>
    <s:String x:Key="Split_Prefix">文件名前缀</s:String>
    <s:String x:Key="Split_PrefixTip">所有输出文件的文件名前缀</s:String>
    <s:String x:Key="Split_Btn">拆分 PDF</s:String>

    <!-- Merge -->
    <s:String x:Key="Merge_Title">合并文档</s:String>
    <s:String x:Key="Merge_Subtitle">按顺序将多个 PDF 文件合并为一个文档。</s:String>
    <s:String x:Key="Merge_FileList">PDF 文件列表</s:String>
    <s:String x:Key="Merge_AddFiles">+ 添加文件</s:String>
    <s:String x:Key="Merge_Clear">清空</s:String>
    <s:String x:Key="Merge_Up">上移</s:String>
    <s:String x:Key="Merge_Down">下移</s:String>
    <s:String x:Key="Merge_Remove">删除</s:String>
    <s:String x:Key="Merge_EmptyTitle">暂无文件</s:String>
    <s:String x:Key="Merge_EmptyHint">点击"添加文件"或将 PDF 拖拽到此处</s:String>
    <s:String x:Key="Merge_Btn">合并 PDF</s:String>

    <!-- Rotate -->
    <s:String x:Key="Rotate_Title">旋转页面</s:String>
    <s:String x:Key="Rotate_Subtitle">旋转所选 PDF 页面并保存为新文件。</s:String>
    <s:String x:Key="Rotate_AllPages">旋转所有页面</s:String>
    <s:String x:Key="Rotate_PageRangeHint">支持单页和范围，例如：1, 3, 5-8, 10-12</s:String>
    <s:String x:Key="Rotate_PageRangeTip">示例：1, 3, 5-8</s:String>
    <s:String x:Key="Rotate_Angle">旋转角度</s:String>
    <s:String x:Key="Rotate_CW90">顺时针 90°</s:String>
    <s:String x:Key="Rotate_180">180°</s:String>
    <s:String x:Key="Rotate_CCW90">逆时针 90°</s:String>
    <s:String x:Key="Rotate_Btn">旋转页面</s:String>

    <!-- Organize -->
    <s:String x:Key="Organize_Title">整理页面</s:String>
    <s:String x:Key="Organize_Subtitle">删除、重新排列或插入 PDF 文档中的页面。</s:String>
    <s:String x:Key="Organize_PageList">页面列表</s:String>
    <s:String x:Key="Organize_MoveUp">&#x2191;  上移</s:String>
    <s:String x:Key="Organize_MoveDown">&#x2193;  下移</s:String>
    <s:String x:Key="Organize_Delete">&#x2715;  删除</s:String>
    <s:String x:Key="Organize_Insert">&#x2295;  从 PDF 插入...</s:String>
    <s:String x:Key="Organize_EmptyTitle">未加载页面</s:String>
    <s:String x:Key="Organize_EmptyHint">打开源 PDF 以开始整理</s:String>
    <s:String x:Key="Organize_InsertTitle">从 PDF 插入页面</s:String>
    <s:String x:Key="Organize_InsertSource">源 PDF</s:String>
    <s:String x:Key="Organize_InsertSourceHint">选择要插入的 PDF 文件...</s:String>
    <s:String x:Key="Organize_InsertPages">页面  (留空 = 全部)</s:String>
    <s:String x:Key="Organize_InsertPagesTip">示例：1, 3, 5-8 — 留空表示全部页面</s:String>
    <s:String x:Key="Organize_InsertPosition">插入到第几页之后</s:String>
    <s:String x:Key="Organize_InsertPositionTip">0 = 插入到开头，留空 = 追加到末尾</s:String>
    <s:String x:Key="Organize_InsertBtn">+ 添加页面到列表</s:String>
    <s:String x:Key="Organize_Btn">保存文档</s:String>

    <!-- Watermark -->
    <s:String x:Key="Wm_Title">文字水印</s:String>
    <s:String x:Key="Wm_Subtitle">在所有页面或指定页面范围上添加文字水印。</s:String>
    <s:String x:Key="Wm_Text">水印文字</s:String>
    <s:String x:Key="Wm_Bold">加粗</s:String>
    <s:String x:Key="Wm_FontSize">字号 (pt)</s:String>
    <s:String x:Key="Wm_FontSizeTip">建议：40-120</s:String>
    <s:String x:Key="Wm_Opacity">透明度 %</s:String>
    <s:String x:Key="Wm_Color">颜色</s:String>
    <s:String x:Key="Wm_Position">位置</s:String>
    <s:String x:Key="Wm_Rotation">旋转</s:String>
    <s:String x:Key="Wm_RotN45">-45°  (斜角)</s:String>
    <s:String x:Key="Wm_Rot0">0°  (水平)</s:String>
    <s:String x:Key="Wm_Rot45">45°</s:String>
    <s:String x:Key="Wm_Rot90">90°  (垂直)</s:String>
    <s:String x:Key="Wm_AllPages">应用到所有页面</s:String>
    <s:String x:Key="Wm_PageRangeHint">单页或范围，例如：1, 3, 5-8, 10-12</s:String>
    <s:String x:Key="Wm_PageRangeTip">示例：1, 3, 5-8</s:String>
    <s:String x:Key="Wm_Btn">应用水印</s:String>

    <!-- Security -->
    <s:String x:Key="Sec_Title">PDF 安全</s:String>
    <s:String x:Key="Sec_Subtitle">为 PDF 添加密码保护，或删除现有密码。</s:String>
    <s:String x:Key="Sec_TabEncrypt">加密 PDF</s:String>
    <s:String x:Key="Sec_TabRemove">删除密码</s:String>
    <s:String x:Key="Sec_CurrentPwd">当前密码  (若未加密请留空)</s:String>
    <s:String x:Key="Sec_UserPwd">用户密码  (打开文档时需要)</s:String>
    <s:String x:Key="Sec_ConfirmPwd">确认密码</s:String>
    <s:String x:Key="Sec_OwnerPwd">所有者密码  (可选)</s:String>
    <s:String x:Key="Sec_OwnerPwdHint">设置后可限制编辑、复制、打印权限。</s:String>
    <s:String x:Key="Sec_Permissions">权限  (使用用户密码打开时生效)</s:String>
    <s:String x:Key="Sec_AllowPrint">允许打印</s:String>
    <s:String x:Key="Sec_AllowCopy">允许复制文本</s:String>
    <s:String x:Key="Sec_AllowModify">允许修改</s:String>
    <s:String x:Key="Sec_EncBtn">加密 PDF</s:String>
    <s:String x:Key="Sec_RemTitle">加密的 PDF 文件</s:String>
    <s:String x:Key="Sec_RemSourceHint">点击浏览以选择加密的 PDF...</s:String>
    <s:String x:Key="Sec_RemCurrentPwd">当前密码</s:String>
    <s:String x:Key="Sec_RemCurrentPwdHint">输入用户密码或所有者密码以解锁文档。</s:String>
    <s:String x:Key="Sec_RemBtn">删除密码</s:String>

    <!-- Metadata -->
    <s:String x:Key="Meta_Title">PDF 元数据</s:String>
    <s:String x:Key="Meta_Subtitle">查看并编辑 PDF 文件中存储的文档属性。</s:String>
    <s:String x:Key="Meta_Load">加载元数据</s:String>
    <s:String x:Key="Meta_FieldTitle">标题</s:String>
    <s:String x:Key="Meta_Subject">主题</s:String>
    <s:String x:Key="Meta_Creator">创建程序</s:String>
    <s:String x:Key="Meta_Author">作者</s:String>
    <s:String x:Key="Meta_Keywords">关键词</s:String>
    <s:String x:Key="Meta_ReadOnly">文档信息  (只读)</s:String>
    <s:String x:Key="Meta_Producer">生成工具</s:String>
    <s:String x:Key="Meta_CreationDate">创建日期</s:String>
    <s:String x:Key="Meta_Btn">保存元数据</s:String>

    <!-- Runtime strings -->
    <s:String x:Key="Rt_PagesDetected">已检测到 {0} 页</s:String>
    <s:String x:Key="Rt_PagesLoaded">已加载 {0} 页</s:String>
    <s:String x:Key="Rt_UnableToRead">无法读取页数</s:String>
    <s:String x:Key="Rt_PasswordProtected">已加密 — 请在下方输入当前密码</s:String>
    <s:String x:Key="Rt_EnterPwdToRemove">请在下方输入密码，然后点击"删除密码"。</s:String>
    <s:String x:Key="Rt_ClickLoadMeta">点击"加载元数据"以读取文档属性。</s:String>

    <s:String x:Key="Err_NoSourcePdf">请先选择有效的源 PDF 文件。</s:String>
    <s:String x:Key="Err_NoPageRange">请输入页码。</s:String>
    <s:String x:Key="Err_NoOutput">请选择输出文件路径。</s:String>
    <s:String x:Key="Err_NoOutputFolder">请选择输出文件夹。</s:String>
    <s:String x:Key="Err_NoPrefix">请输入文件名前缀。</s:String>
    <s:String x:Key="Err_NoPages">列表中没有页面，请先加载源 PDF。</s:String>
    <s:String x:Key="Err_NoInsertSource">请选择有效的要插入的 PDF 文件。</s:String>
    <s:String x:Key="Err_EnterPagesOrAll">请输入页码或启用"旋转所有页面"。</s:String>
    <s:String x:Key="Err_EnterPagesOrAllWm">请输入页码或启用"应用到所有页面"。</s:String>
    <s:String x:Key="Err_WmTextEmpty">水印文字不能为空。</s:String>
    <s:String x:Key="Err_NoPagesPerFile">每个文件的页数必须是大于等于 1 的整数。</s:String>
    <s:String x:Key="Err_NoRanges">请输入页面范围。</s:String>
    <s:String x:Key="Err_UserPwdRequired">加密时必须设置用户密码。</s:String>
    <s:String x:Key="Err_PwdMismatch">两次输入的密码不一致，请重新确认。</s:String>

    <s:String x:Key="Ok_Extracted">已提取 {0} 页 → {1}</s:String>
    <s:String x:Key="Ok_Merged">已合并 {0} 个文件（共 {1} 页）→ {2}</s:String>
    <s:String x:Key="Ok_Rotated">已旋转 {0} 页（{1}°）→ {2}</s:String>
    <s:String x:Key="Ok_Saved">已保存 {0} 页 → {1}</s:String>
    <s:String x:Key="Ok_Encrypted">PDF 加密成功 → {0}</s:String>
    <s:String x:Key="Ok_PwdRemoved">密码已删除 → {0}</s:String>
    <s:String x:Key="Ok_WatermarkApplied">水印已应用（{0} 页）→ {1}</s:String>
    <s:String x:Key="Ok_MetaSaved">元数据已保存 → {0}</s:String>
    <s:String x:Key="Ok_Split">已拆分为 {0} 个文件 → {1}</s:String>
    <s:String x:Key="Err_RemovePwdFailed">操作失败：{0} — 请确认密码是否正确。</s:String>

    <!-- Dialog titles -->
    <s:String x:Key="Dlg_SelectPdf">选择 PDF 文件</s:String>
    <s:String x:Key="Dlg_SelectPdfs">选择 PDF 文件</s:String>
    <s:String x:Key="Dlg_SelectFolder">选择拆分文件的输出文件夹</s:String>
    <s:String x:Key="Dlg_SavePdf">保存 PDF 文件</s:String>

</ResourceDictionary>

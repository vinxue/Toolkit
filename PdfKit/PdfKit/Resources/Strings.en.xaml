<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">

    <!-- App -->
    <s:String x:Key="App_Title">PdfKit - PDF Toolkit</s:String>
    <s:String x:Key="App_Subtitle">PDF Toolkit</s:String>

    <!-- Sidebar groups -->
    <s:String x:Key="Nav_Organize">ORGANIZE</s:String>
    <s:String x:Key="Nav_Enhance">ENHANCE</s:String>
    <s:String x:Key="Nav_Document">DOCUMENT</s:String>

    <!-- Nav items -->
    <s:String x:Key="Nav_Extract">Extract Pages</s:String>
    <s:String x:Key="Nav_Split">Split PDF</s:String>
    <s:String x:Key="Nav_Merge">Merge Documents</s:String>
    <s:String x:Key="Nav_Organize_Pages">Organize Pages</s:String>
    <s:String x:Key="Nav_Rotate">Rotate Pages</s:String>
    <s:String x:Key="Nav_Watermark">Text Watermark</s:String>
    <s:String x:Key="Nav_Metadata">PDF Metadata</s:String>
    <s:String x:Key="Nav_Security">PDF Security</s:String>

    <!-- Language switcher -->
    <s:String x:Key="Lang_Label">Language</s:String>
    <s:String x:Key="Lang_EN">English</s:String>
    <s:String x:Key="Lang_ZH_CN">简体中文</s:String>
    <s:String x:Key="Lang_ZH_TW">繁體中文</s:String>

    <!-- Common -->
    <s:String x:Key="Btn_Browse">Browse</s:String>
    <s:String x:Key="Btn_Close">Close</s:String>
    <s:String x:Key="Lbl_SourcePdf">Source PDF File</s:String>
    <s:String x:Key="Lbl_OutputFile">Output File</s:String>
    <s:String x:Key="Lbl_PageRange">Page Range</s:String>
    <s:String x:Key="Hint_BrowseSource">Click Browse to select a PDF file...</s:String>
    <s:String x:Key="Hint_BrowseOutput">Click Browse to choose a save location...</s:String>

    <!-- Extract -->
    <s:String x:Key="Extract_Title">Extract Pages</s:String>
    <s:String x:Key="Extract_Subtitle">Extract selected pages from a PDF into a new file.</s:String>
    <s:String x:Key="Extract_PageRangeHint">Supports single pages and ranges, for example: 1, 3, 5-8, 10-12</s:String>
    <s:String x:Key="Extract_PageRangeTip">Example: 1, 3, 5-8, 10</s:String>
    <s:String x:Key="Extract_Btn">Extract Pages</s:String>

    <!-- Split -->
    <s:String x:Key="Split_Title">Split PDF</s:String>
    <s:String x:Key="Split_Subtitle">Split a PDF into multiple files by page count or custom page ranges.</s:String>
    <s:String x:Key="Split_TabCount">By Page Count</s:String>
    <s:String x:Key="Split_TabRanges">By Page Ranges</s:String>
    <s:String x:Key="Split_PagesPerFile">Pages Per File</s:String>
    <s:String x:Key="Split_PagesPerFileTip">Number of pages in each split file</s:String>
    <s:String x:Key="Split_PagesPerFileHint">e.g. 1 = split each page individually, 3 = group every 3 pages</s:String>
    <s:String x:Key="Split_PageRanges">Page Ranges</s:String>
    <s:String x:Key="Split_PageRangesTip">Separate each output file with semicolons</s:String>
    <s:String x:Key="Split_PageRangesHint">Each semicolon-separated group becomes one file  |  e.g.  1-5 ; 6, 8-10 ; 11-15</s:String>
    <s:String x:Key="Split_OutputFolder">Output Folder</s:String>
    <s:String x:Key="Split_BrowseFolder">Click Browse to choose a folder...</s:String>
    <s:String x:Key="Split_Prefix">File Name Prefix</s:String>
    <s:String x:Key="Split_PrefixTip">Prefix used for all output file names</s:String>
    <s:String x:Key="Split_Btn">Split PDF</s:String>

    <!-- Merge -->
    <s:String x:Key="Merge_Title">Merge Documents</s:String>
    <s:String x:Key="Merge_Subtitle">Merge multiple PDF files into one document in order.</s:String>
    <s:String x:Key="Merge_FileList">PDF File List</s:String>
    <s:String x:Key="Merge_AddFiles">+ Add Files</s:String>
    <s:String x:Key="Merge_Clear">Clear</s:String>
    <s:String x:Key="Merge_Up">Up</s:String>
    <s:String x:Key="Merge_Down">Down</s:String>
    <s:String x:Key="Merge_Remove">Remove</s:String>
    <s:String x:Key="Merge_EmptyTitle">No files yet</s:String>
    <s:String x:Key="Merge_EmptyHint">Click Add Files or drag and drop PDFs here</s:String>
    <s:String x:Key="Merge_Btn">Merge PDFs</s:String>

    <!-- Rotate -->
    <s:String x:Key="Rotate_Title">Rotate Pages</s:String>
    <s:String x:Key="Rotate_Subtitle">Rotate selected PDF pages and save as a new file.</s:String>
    <s:String x:Key="Rotate_AllPages">Rotate all pages</s:String>
    <s:String x:Key="Rotate_PageRangeHint">Supports single pages and ranges, for example: 1, 3, 5-8, 10-12</s:String>
    <s:String x:Key="Rotate_PageRangeTip">Example: 1, 3, 5-8</s:String>
    <s:String x:Key="Rotate_Angle">Rotation Angle</s:String>
    <s:String x:Key="Rotate_CW90">Clockwise 90°</s:String>
    <s:String x:Key="Rotate_180">180°</s:String>
    <s:String x:Key="Rotate_CCW90">Counterclockwise 90°</s:String>
    <s:String x:Key="Rotate_Btn">Rotate Pages</s:String>

    <!-- Organize -->
    <s:String x:Key="Organize_Title">Organize Pages</s:String>
    <s:String x:Key="Organize_Subtitle">Delete, reorder, and insert pages within a PDF document.</s:String>
    <s:String x:Key="Organize_PageList">Page List</s:String>
    <s:String x:Key="Organize_MoveUp">&#x2191;  Up</s:String>
    <s:String x:Key="Organize_MoveDown">&#x2193;  Down</s:String>
    <s:String x:Key="Organize_Delete">&#x2715;  Delete</s:String>
    <s:String x:Key="Organize_Insert">&#x2295;  Insert from PDF...</s:String>
    <s:String x:Key="Organize_EmptyTitle">No pages loaded</s:String>
    <s:String x:Key="Organize_EmptyHint">Open a source PDF to start organizing</s:String>
    <s:String x:Key="Organize_InsertTitle">Insert Pages from PDF</s:String>
    <s:String x:Key="Organize_InsertSource">Source PDF</s:String>
    <s:String x:Key="Organize_InsertSourceHint">Select a PDF to insert from...</s:String>
    <s:String x:Key="Organize_InsertPages">Pages  (blank = all)</s:String>
    <s:String x:Key="Organize_InsertPagesTip">Example: 1, 3, 5-8 — leave blank for all pages</s:String>
    <s:String x:Key="Organize_InsertPosition">Insert After Position</s:String>
    <s:String x:Key="Organize_InsertPositionTip">0 = start of document, blank = append at end</s:String>
    <s:String x:Key="Organize_InsertBtn">+ Add Pages to List</s:String>
    <s:String x:Key="Organize_Btn">Save Document</s:String>

    <!-- Watermark -->
    <s:String x:Key="Wm_Title">Text Watermark</s:String>
    <s:String x:Key="Wm_Subtitle">Stamp a text watermark onto every page or a specific page range.</s:String>
    <s:String x:Key="Wm_Text">Watermark Text</s:String>
    <s:String x:Key="Wm_Bold">Bold</s:String>
    <s:String x:Key="Wm_FontSize">Font Size (pt)</s:String>
    <s:String x:Key="Wm_FontSizeTip">Recommended: 40-120</s:String>
    <s:String x:Key="Wm_Opacity">Opacity %</s:String>
    <s:String x:Key="Wm_Color">Color</s:String>
    <s:String x:Key="Wm_Position">Position</s:String>
    <s:String x:Key="Wm_Rotation">Rotation</s:String>
    <s:String x:Key="Wm_RotN45">-45°  (diagonal)</s:String>
    <s:String x:Key="Wm_Rot0">0°  (horizontal)</s:String>
    <s:String x:Key="Wm_Rot45">45°</s:String>
    <s:String x:Key="Wm_Rot90">90°  (vertical)</s:String>
    <s:String x:Key="Wm_AllPages">Apply to all pages</s:String>
    <s:String x:Key="Wm_PageRangeHint">Single pages or ranges, e.g. 1, 3, 5-8, 10-12</s:String>
    <s:String x:Key="Wm_PageRangeTip">Example: 1, 3, 5-8</s:String>
    <s:String x:Key="Wm_Btn">Apply Watermark</s:String>

    <!-- Security -->
    <s:String x:Key="Sec_Title">PDF Security</s:String>
    <s:String x:Key="Sec_Subtitle">Encrypt a PDF with password protection, or remove an existing password.</s:String>
    <s:String x:Key="Sec_TabEncrypt">Encrypt PDF</s:String>
    <s:String x:Key="Sec_TabRemove">Remove Password</s:String>
    <s:String x:Key="Sec_CurrentPwd">Current Password  (leave blank if source is not encrypted)</s:String>
    <s:String x:Key="Sec_UserPwd">User Password  (optional)</s:String>
    <s:String x:Key="Sec_UserPwdHint">When set, required to open the document.</s:String>
    <s:String x:Key="Sec_ConfirmPwd">Confirm User Password</s:String>
    <s:String x:Key="Sec_OwnerPwd">Owner Password  (optional)</s:String>
    <s:String x:Key="Sec_OwnerPwdHint">When set, controls edit / copy / print restrictions.</s:String>
    <s:String x:Key="Sec_PwdAtLeastOne">At least one password (user or owner) must be provided.</s:String>
    <s:String x:Key="Sec_Permissions">Permissions  (applied when Owner Password is set)</s:String>
    <s:String x:Key="Sec_AllowPrint">Allow Printing</s:String>
    <s:String x:Key="Sec_AllowCopy">Allow Copying Text</s:String>
    <s:String x:Key="Sec_AllowModify">Allow Modifications</s:String>
    <s:String x:Key="Sec_EncBtn">Encrypt PDF</s:String>
    <s:String x:Key="Sec_RemTitle">Encrypted PDF File</s:String>
    <s:String x:Key="Sec_RemSourceHint">Click Browse to select an encrypted PDF...</s:String>
    <s:String x:Key="Sec_RemCurrentPwd">Current Password</s:String>
    <s:String x:Key="Sec_RemCurrentPwdHint">Enter the user or owner password to unlock the document.</s:String>
    <s:String x:Key="Sec_RemBtn">Remove Password</s:String>

    <!-- Metadata -->
    <s:String x:Key="Meta_Title">PDF Metadata</s:String>
    <s:String x:Key="Meta_Subtitle">View and edit the document properties stored inside a PDF file.</s:String>
    <s:String x:Key="Meta_Load">Load Metadata</s:String>
    <s:String x:Key="Meta_FieldTitle">Title</s:String>
    <s:String x:Key="Meta_Subject">Subject</s:String>
    <s:String x:Key="Meta_Creator">Creator</s:String>
    <s:String x:Key="Meta_Author">Author</s:String>
    <s:String x:Key="Meta_Keywords">Keywords</s:String>
    <s:String x:Key="Meta_ReadOnly">Document Information  (read-only)</s:String>
    <s:String x:Key="Meta_Producer">Producer</s:String>
    <s:String x:Key="Meta_CreationDate">Creation Date</s:String>
    <s:String x:Key="Meta_Btn">Save Metadata</s:String>

    <!-- Runtime strings (used from code-behind) -->
    <s:String x:Key="Rt_PagesDetected">{0} pages detected</s:String>
    <s:String x:Key="Rt_PagesLoaded">{0} pages loaded</s:String>
    <s:String x:Key="Rt_UnableToRead">Unable to read page count</s:String>
    <s:String x:Key="Rt_PasswordProtected">Password-protected — enter current password below</s:String>
    <s:String x:Key="Rt_EnterPwdToRemove">Enter the password below, then click Remove Password.</s:String>
    <s:String x:Key="Rt_ClickLoadMeta">Click Load Metadata to read document properties.</s:String>

    <s:String x:Key="Err_NoSourcePdf">Please choose a valid source PDF first.</s:String>
    <s:String x:Key="Err_NoPageRange">Please enter page numbers.</s:String>
    <s:String x:Key="Err_NoOutput">Please choose an output file path.</s:String>
    <s:String x:Key="Err_NoOutputFolder">Please select an output folder.</s:String>
    <s:String x:Key="Err_NoPrefix">Please enter a file name prefix.</s:String>
    <s:String x:Key="Err_NoPages">No pages in list. Load a source PDF first.</s:String>
    <s:String x:Key="Err_NoInsertSource">Please select a valid PDF to insert from.</s:String>
    <s:String x:Key="Err_EnterPagesOrAll">Enter page numbers or enable Rotate all pages.</s:String>
    <s:String x:Key="Err_EnterPagesOrAllWm">Enter page numbers or enable Apply to all pages.</s:String>
    <s:String x:Key="Err_WmTextEmpty">Watermark text cannot be empty.</s:String>
    <s:String x:Key="Err_NoPagesPerFile">Pages per file must be a whole number >= 1.</s:String>
    <s:String x:Key="Err_NoRanges">Please enter page ranges.</s:String>
    <s:String x:Key="Err_UserPwdRequired">User password is required for encryption.</s:String>
    <s:String x:Key="Err_NoPwdProvided">Please enter at least one password (user or owner).</s:String>
    <s:String x:Key="Err_PwdMismatch">Passwords do not match — please confirm the user password.</s:String>

    <s:String x:Key="Ok_Extracted">Extracted {0} pages → {1}</s:String>
    <s:String x:Key="Ok_Merged">Merged {0} files ({1} pages total) → {2}</s:String>
    <s:String x:Key="Ok_Rotated">Rotated {0} pages ({1}°) → {2}</s:String>
    <s:String x:Key="Ok_Saved">Saved {0} pages → {1}</s:String>
    <s:String x:Key="Ok_Encrypted">PDF encrypted successfully → {0}</s:String>
    <s:String x:Key="Ok_PwdRemoved">Password removed → {0}</s:String>
    <s:String x:Key="Ok_WatermarkApplied">Watermark applied ({0} pages) → {1}</s:String>
    <s:String x:Key="Ok_MetaSaved">Metadata saved → {0}</s:String>
    <s:String x:Key="Ok_Split">Split into {0} files → {1}</s:String>
    <s:String x:Key="Err_RemovePwdFailed">Failed: {0} — verify that the password is correct.</s:String>

    <!-- Dialog titles -->
    <s:String x:Key="Dlg_SelectPdf">Select PDF file</s:String>
    <s:String x:Key="Dlg_SelectPdfs">Select PDF files</s:String>
    <s:String x:Key="Dlg_SelectFolder">Select output folder for split files</s:String>
    <s:String x:Key="Dlg_SavePdf">Save PDF file</s:String>

</ResourceDictionary>

<Window x:Class="Nexus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nexus"
        mc:Ignorable="d"
        Title="Nexus" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left sidebar: pushes the content column aside when expanded. This is a
             deliberate choice over a floating/overlay sidebar: WebView2 renders in its
             own native child window, which always paints on top of WPF content
             regardless of Z-order, so a WPF sidebar cannot visually overlap it. -->
        <Border x:Name="SidebarPanel"
                Grid.Column="0"
                Width="60"
                Background="{StaticResource SidebarBackground}"
                BorderBrush="{StaticResource SidebarBorder}"
                BorderThickness="0,0,1,0">

            <DockPanel LastChildFill="True">

                <!-- Header: hamburger toggle -->
                <Grid DockPanel.Dock="Top" Height="52">
                    <Button x:Name="ToggleButton"
                            Style="{StaticResource IconButton}"
                            Width="40" Height="40"
                            HorizontalAlignment="Left"
                            Margin="8,0,0,0"
                            Content="&#9776;"
                            ToolTip="Expand / collapse"
                            Click="ToggleButton_Click" />
                </Grid>

                <!-- Footer: add site -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource SidebarBorder}"
                        BorderThickness="0,1,0,0">
                    <Button x:Name="AddSiteButton"
                            Style="{StaticResource IconButton}"
                            Height="46"
                            Margin="8"
                            HorizontalContentAlignment="Left"
                            Click="AddSiteButton_Click"
                            ToolTip="Add a website">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#65291;"
                                       FontSize="18"
                                       Width="40"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Add site"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{StaticResource SidebarText}"
                                       Visibility="{Binding IsSidebarExpanded,
                                           RelativeSource={RelativeSource AncestorType=Window},
                                           Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Site list -->
                <ListBox x:Name="SiteList"
                         AllowDrop="True"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch"
                         SelectionChanged="SiteList_SelectionChanged"
                         PreviewMouseLeftButtonDown="SiteList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="SiteList_PreviewMouseMove"
                         DragOver="SiteList_DragOver"
                         Drop="SiteList_Drop">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="4,2" />
                            <Setter Property="Foreground" Value="{StaticResource SidebarText}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="Transparent"
                                                CornerRadius="6"
                                                Padding="1">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background"
                                                        Value="{StaticResource SidebarHover}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background"
                                                        Value="{StaticResource SidebarSelected}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="40" ToolTip="{Binding Name}">
                                <Grid.ColumnDefinitions>
                                    <!-- Fixed (not Auto) so the avatar's centered position
                                         never shifts between collapsed and expanded states:
                                         this width equals the full row content width when
                                         collapsed, so the avatar sits centered there too. -->
                                    <ColumnDefinition Width="49" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Grid.Column="0"
                                        Width="32" Height="32"
                                        Margin="4,0"
                                        HorizontalAlignment="Center"
                                        CornerRadius="16"
                                        Background="{StaticResource AvatarBackground}">
                                    <TextBlock Text="{Binding Initial}"
                                               Foreground="White"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <!-- Name (hidden when collapsed) -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,4,0"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource SidebarText}"
                                           Visibility="{Binding IsSidebarExpanded,
                                               RelativeSource={RelativeSource AncestorType=Window},
                                               Converter={StaticResource BoolToVis}}" />
                                <!-- Remove (hidden when collapsed) -->
                                <Button Grid.Column="2"
                                        Style="{StaticResource IconButton}"
                                        Width="26" Height="26"
                                        FontSize="12"
                                        Margin="0,0,6,0"
                                        Content="&#10005;"
                                        ToolTip="Remove this site"
                                        Click="DeleteSite_Click"
                                        Visibility="{Binding IsSidebarExpanded,
                                            RelativeSource={RelativeSource AncestorType=Window},
                                            Converter={StaticResource BoolToVis}}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Web content host -->
        <Grid x:Name="WebHost" Grid.Column="1" Background="#FFFFFF">
            <TextBlock x:Name="EmptyHint"
                       Text="Select a site from the left to get started."
                       Foreground="#8A94A6"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="LoadingHint"
                       Text="Loading..."
                       Foreground="#8A94A6"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
            <TextBlock x:Name="ErrorHint"
                       Foreground="#DC2626"
                       FontSize="14"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="40"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>

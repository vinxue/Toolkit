<UserControl x:Class="FileForge.Views.AlignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True" Drop="View_Drop" DragOver="View_DragOver">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,20">
            <TextBlock Text="Align &amp; Pad" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Extend a file to the next alignment boundary — useful for flash images, ROM blobs, and sector-aligned formats."
                       Style="{StaticResource SectionSubtitleStyle}"/>

            <!-- Source File -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="SOURCE FILE" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtInput" Grid.Column="0" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Browse…" Width="90"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnBrowseInput_Click"/>
                    </Grid>
                    <TextBlock x:Name="txtInputInfo" Foreground="#616161" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Settings -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="ALIGNMENT BOUNDARY" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="cboAlign" Width="240" HorizontalAlignment="Left"
                              SelectionChanged="CboAlign_Changed" Margin="0,0,0,14">
                        <ComboBoxItem Content="512 B  (sector)"/>
                        <ComboBoxItem Content="4 KB  (page)"/>
                        <ComboBoxItem Content="64 KB"/>
                        <ComboBoxItem Content="512 KB"/>
                        <ComboBoxItem Content="1 MB" IsSelected="True"/>
                        <ComboBoxItem Content="4 MB"/>
                        <ComboBoxItem Content="Custom…"/>
                    </ComboBox>
                    <StackPanel x:Name="panelCustomAlign" Visibility="Collapsed" Margin="0,0,0,14">
                        <TextBlock Text="CUSTOM ALIGNMENT  (bytes, e.g. 0x10000)"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtCustomAlign" Width="200" HorizontalAlignment="Left"
                                 Text="0x10000" TextChanged="AlignInput_Changed"/>
                    </StackPanel>

                    <TextBlock Text="FILL BYTE" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="cboFillByte" Width="200" HorizontalAlignment="Left"
                              SelectionChanged="CboFillByte_Changed" Margin="0,0,0,14">
                        <ComboBoxItem Content="0x00  (zeros)" IsSelected="True"/>
                        <ComboBoxItem Content="0xFF  (erased flash)"/>
                        <ComboBoxItem Content="Custom…"/>
                    </ComboBox>
                    <StackPanel x:Name="panelCustomByte" Visibility="Collapsed" Margin="0,0,0,14">
                        <TextBlock Text="CUSTOM BYTE  (hex, e.g. AA)"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtCustomByte" Width="120" HorizontalAlignment="Left"
                                 Text="AA" TextChanged="AlignInput_Changed"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Preview -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ORIGINAL SIZE" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock x:Name="txtPreviewOriginal" Text="—" FontSize="14" Foreground="#1A1A1A"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="PAD BYTES" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock x:Name="txtPreviewPad" Text="—" FontSize="14" Foreground="#0078D4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ALIGNED SIZE" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock x:Name="txtPreviewNew" Text="—" FontSize="14" Foreground="#1A1A1A"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Output File -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="OUTPUT FILE" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtOutput" Grid.Column="0" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Browse…" Width="90"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnBrowseOutput_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Align File" Width="120" Height="36"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="BtnExecute_Click"/>
            </StackPanel>

            <TextBlock x:Name="txtStatus" TextWrapping="Wrap" Margin="0,10,0,0" FontSize="13"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

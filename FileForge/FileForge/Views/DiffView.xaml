<UserControl x:Class="FileForge.Views.DiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True" Drop="View_Drop" DragOver="View_DragOver">
    <UserControl.Resources>
        <Style x:Key="MonoCellStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Padding"    Value="4,0"/>
        </Style>
    </UserControl.Resources>
    <DockPanel>
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0">
            <TextBlock Text="File Diff" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Compare two binary files byte by byte and list every difference."
                       Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <!-- File selection -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardStyle}" Margin="0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- File A -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="FILE A" Style="{StaticResource FieldLabelStyle}"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse…" Width="90"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="6,0,0,0" Click="BtnBrowseA_Click"/>
                        <TextBox x:Name="txtFileA"/>
                    </DockPanel>
                    <TextBlock x:Name="txtInfoA" Foreground="#616161" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- File B -->
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="FILE B" Style="{StaticResource FieldLabelStyle}"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse…" Width="90"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="6,0,0,0" Click="BtnBrowseB_Click"/>
                        <TextBox x:Name="txtFileB"/>
                    </DockPanel>
                    <TextBlock x:Name="txtInfoB" Foreground="#616161" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Actions + summary -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                Margin="0,4,0,8">
            <Button Content="Compare Files" Width="140" Height="36"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="BtnCompare_Click"/>
            <Button x:Name="btnExport" Content="Export Report" Width="130" Height="36"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="8,0,0,0" Visibility="Collapsed"
                    Click="BtnExport_Click"/>
            <TextBlock x:Name="txtStatus" VerticalAlignment="Center"
                       Margin="14,0,0,0" FontSize="13" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Results DataGrid -->
        <Border Margin="0,0,0,20" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="gridDiffs"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="White"
                      AlternatingRowBackground="#F9F9F9"
                      ColumnHeaderHeight="36"
                      RowHeight="28"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      FontFamily="Consolas" FontSize="12">
                <DataGrid.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width"    Value="14"/>
                        <Setter Property="MinWidth" Value="14"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent" Margin="0,4,0,4">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineUpCommand" Height="0" MinHeight="0" Opacity="0" Focusable="False" IsTabStop="False"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineDownCommand" Height="0" MinHeight="0" Opacity="0" Focusable="False" IsTabStop="False"/>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb MinHeight="44">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border x:Name="bd" Background="#BABBBE" CornerRadius="0" Margin="2,1"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#888"/></Trigger>
                                                                <Trigger Property="IsDragging"  Value="True"><Setter TargetName="bd" Property="Background" Value="#555"/></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Offset" Binding="{Binding OffsetHex}" Width="120" MinWidth="100"
                                        ElementStyle="{StaticResource MonoCellStyle}"/>
                    <DataGridTextColumn Header="File A  (hex)" Binding="{Binding ValueAHex}" Width="120" MinWidth="80"
                                        ElementStyle="{StaticResource MonoCellStyle}"/>
                    <DataGridTextColumn Header="File B  (hex)" Binding="{Binding ValueBHex}" Width="120" MinWidth="80"
                                        ElementStyle="{StaticResource MonoCellStyle}"/>
                    <DataGridTextColumn Header="File A  (char)" Binding="{Binding CharA}" Width="120" MinWidth="70"/>
                    <DataGridTextColumn Header="File B  (char)" Binding="{Binding CharB}" Width="120" MinWidth="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>

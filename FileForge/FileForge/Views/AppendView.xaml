<UserControl x:Class="FileForge.Views.AppendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True" Drop="View_Drop" DragOver="View_DragOver">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="0,20">

            <TextBlock Text="Append / Prepend" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Add fill data before and/or after a file. Specify exact fill sizes or work backwards from a target total size."
                       Style="{StaticResource SectionSubtitleStyle}"/>

            <!-- Source File -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="SOURCE FILE" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtInput" Grid.Column="0" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Browse…" Width="90"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnBrowseInput_Click"/>
                    </Grid>
                    <TextBlock x:Name="txtInputInfo" Foreground="#616161" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Position + Size Mode -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>

                    <!-- POSITION -->
                    <TextBlock Text="POSITION" Style="{StaticResource FieldLabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <RadioButton x:Name="rdoPrepend" Content="Prepend  (before file)"
                                     GroupName="AppPos" IsChecked="True"
                                     Checked="Position_Changed"/>
                        <RadioButton x:Name="rdoAppend"  Content="Append  (after file)"
                                     GroupName="AppPos" Checked="Position_Changed"/>
                        <RadioButton x:Name="rdoBoth"    Content="Both"
                                     GroupName="AppPos" Checked="Position_Changed"/>
                    </StackPanel>

                    <!-- ─── Single-side size panel (Prepend or Append) ─── -->
                    <StackPanel x:Name="panelSingle">
                        <TextBlock Text="SIZE MODE" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Margin="0,0,0,14">
                            <RadioButton x:Name="rdoExactSingle" Content="Exact fill size"
                                         GroupName="SzMode" IsChecked="True"
                                         Checked="SizeMode_Changed"/>
                            <RadioButton x:Name="rdoTotalSingle" Content="Target total file size  (fill = total − source)"
                                         GroupName="SzMode" Margin="0,6,0,0"
                                         Checked="SizeMode_Changed"/>
                        </StackPanel>

                        <!-- Exact fill size row -->
                        <StackPanel x:Name="panelExactFill">
                            <TextBlock Text="FILL SIZE" Style="{StaticResource FieldLabelStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBox x:Name="txtFillSize" Width="160" Text="512"
                                         TextChanged="SizeInput_Changed"/>
                                <ComboBox x:Name="cboFillUnit" Width="80" Margin="8,0,0,0" SelectedIndex="0"
                                          SelectionChanged="SizeInput_Changed">
                                    <ComboBoxItem Content="Bytes"/>
                                    <ComboBoxItem Content="KB"/>
                                    <ComboBoxItem Content="MB"/>
                                    <ComboBoxItem Content="GB"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>

                        <!-- Target total size row -->
                        <StackPanel x:Name="panelTotalFill" Visibility="Collapsed">
                            <TextBlock Text="TARGET TOTAL SIZE" Style="{StaticResource FieldLabelStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBox x:Name="txtTotalSize" Width="160" Text=""
                                         TextChanged="SizeInput_Changed"/>
                                <ComboBox x:Name="cboTotalUnit" Width="80" Margin="8,0,0,0" SelectedIndex="2"
                                          SelectionChanged="SizeInput_Changed">
                                    <ComboBoxItem Content="Bytes"/>
                                    <ComboBoxItem Content="KB"/>
                                    <ComboBoxItem Content="MB"/>
                                    <ComboBoxItem Content="GB"/>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock x:Name="txtCalcFill" Foreground="#0078D4" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ─── Both-sides size panel ─── -->
                    <StackPanel x:Name="panelBoth" Visibility="Collapsed">
                        <TextBlock Text="FILL SIZES  —  specify any two values; the third is calculated automatically"
                                   Style="{StaticResource FieldLabelStyle}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <!-- Front fill -->
                        <TextBlock Text="FRONT FILL (prepend)" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBox x:Name="txtFrontSize" Width="160" Text=""
                                     Tag="Leave blank to auto-calculate"
                                     TextChanged="BothSizeInput_Changed"/>
                            <ComboBox x:Name="cboFrontUnit" Width="80" Margin="8,0,0,0" SelectedIndex="0"
                                      SelectionChanged="BothSizeInput_Changed">
                                <ComboBoxItem Content="Bytes"/>
                                <ComboBoxItem Content="KB"/>
                                <ComboBoxItem Content="MB"/>
                                <ComboBoxItem Content="GB"/>
                            </ComboBox>
                            <TextBlock x:Name="txtFrontCalc" Foreground="#0078D4" FontSize="12"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>

                        <!-- Back fill -->
                        <TextBlock Text="BACK FILL (append)" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBox x:Name="txtBackSize" Width="160" Text=""
                                     Tag="Leave blank to auto-calculate"
                                     TextChanged="BothSizeInput_Changed"/>
                            <ComboBox x:Name="cboBackUnit" Width="80" Margin="8,0,0,0" SelectedIndex="0"
                                      SelectionChanged="BothSizeInput_Changed">
                                <ComboBoxItem Content="Bytes"/>
                                <ComboBoxItem Content="KB"/>
                                <ComboBoxItem Content="MB"/>
                                <ComboBoxItem Content="GB"/>
                            </ComboBox>
                            <TextBlock x:Name="txtBackCalc" Foreground="#0078D4" FontSize="12"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>

                        <!-- Target total -->
                        <TextBlock Text="TARGET TOTAL SIZE (optional)" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBox x:Name="txtBothTotalSize" Width="160" Text=""
                                     Tag="Leave blank if specifying both fills"
                                     TextChanged="BothSizeInput_Changed"/>
                            <ComboBox x:Name="cboBothTotalUnit" Width="80" Margin="8,0,0,0" SelectedIndex="2"
                                      SelectionChanged="BothSizeInput_Changed">
                                <ComboBoxItem Content="Bytes"/>
                                <ComboBoxItem Content="KB"/>
                                <ComboBoxItem Content="MB"/>
                                <ComboBoxItem Content="GB"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock x:Name="txtBothCalcSummary" Foreground="#616161" FontSize="12"
                                   Margin="0,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Fill Content -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="FILL CONTENT" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="cboFillMode" Width="260" HorizontalAlignment="Left"
                              SelectionChanged="CboFillMode_SelectionChanged">
                        <ComboBoxItem Content="All Zeros  (0x00)" IsSelected="True"/>
                        <ComboBoxItem Content="Specific Byte"/>
                        <ComboBoxItem Content="Hex Pattern  (repeating)"/>
                        <ComboBoxItem Content="Random Data"/>
                    </ComboBox>
                    <StackPanel x:Name="panelSpecByte" Visibility="Collapsed" Margin="0,12,0,0">
                        <TextBlock Text="BYTE VALUE  (hex, e.g. FF)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtSpecByte" Width="120" HorizontalAlignment="Left" Text="FF"/>
                    </StackPanel>
                    <StackPanel x:Name="panelHexPat" Visibility="Collapsed" Margin="0,12,0,0">
                        <TextBlock Text="HEX PATTERN  (e.g. DE AD BE EF)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtHexPat" Width="360" HorizontalAlignment="Left" Text="DE AD BE EF"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output File -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="OUTPUT FILE" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtOutput" Grid.Column="0" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Browse…" Width="90"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnBrowseOutput_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnExecute" Content="Execute" Width="120" Height="36"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="BtnExecute_Click"/>
            </StackPanel>

            <TextBlock x:Name="txtStatus" TextWrapping="Wrap" Margin="0,10,0,20" FontSize="13"/>

    </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="FileForge.Views.MergeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FileForge.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,20,0,0">
            <TextBlock Text="Merge Files" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Combine multiple files into one, with optional separator bytes between them."
                       Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- File list -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,12,12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="SOURCE FILES  (in merge order)"
                               Style="{StaticResource FieldLabelStyle}"/>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Add Files…" Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,0" Click="BtnAddFiles_Click"/>
                        <Button Content="Remove" Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,0" Margin="6,0,0,0" Click="BtnRemove_Click"/>
                        <Button Content="Up" Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,0" Margin="6,0,0,0" Click="BtnMoveUp_Click"/>
                        <Button Content="Down" Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,0" Margin="6,0,0,0" Click="BtnMoveDown_Click"/>
                        <Button Content="Clear" Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,0" Margin="6,0,0,0" Click="BtnClear_Click"/>
                    </StackPanel>
                    <ListBox x:Name="lstFiles" Margin="0,6,0,0"
                             AllowDrop="True" Drop="LstFiles_Drop" DragOver="LstFiles_DragOver"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12" MinHeight="100"/>
                </DockPanel>
            </Border>

            <!-- Right panel -->
            <StackPanel Grid.Column="1">
                <!-- Separator -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="SEPARATOR BETWEEN FILES"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="cboSepMode" SelectionChanged="CboSepMode_Changed">
                            <ComboBoxItem Content="None" IsSelected="True"/>
                            <ComboBoxItem Content="Hex pattern"/>
                            <ComboBoxItem Content="N zero bytes"/>
                        </ComboBox>
                        <StackPanel x:Name="panelSepHex" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="HEX BYTES  (e.g. FF FF FF FF)"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtSepHex" Text="FF FF FF FF"/>
                        </StackPanel>
                        <StackPanel x:Name="panelSepZero" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="COUNT  (bytes)" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtSepZeroCount" Text="16"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Output -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="OUTPUT FILE" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtOutput" Margin="0,0,0,6"/>
                        <Button Content="Browse…" Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left" Padding="16,0"
                                Click="BtnBrowseOutput_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Actions + Status -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Merge Files" Width="130" Height="36"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="BtnExecute_Click"/>
            </StackPanel>
            <local:StatusBanner x:Name="statusBanner"/>
        </StackPanel>
    </Grid>
</UserControl>

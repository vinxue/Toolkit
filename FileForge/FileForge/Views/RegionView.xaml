<UserControl x:Class="FileForge.Views.RegionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True" Drop="View_Drop" DragOver="View_DragOver">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,20,0,0">
            <TextBlock Text="Region Edit" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Extract, insert, delete, overwrite or truncate byte regions within a file."
                       Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <!-- Source file (shared) -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0">
            <StackPanel>
                <TextBlock Text="SOURCE FILE" Style="{StaticResource FieldLabelStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtInput" Grid.Column="0" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Browse…" Width="90"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BtnBrowseInput_Click"/>
                </Grid>
                <TextBlock x:Name="txtInputInfo" Foreground="#616161" FontSize="12" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- TabControl for operations -->
        <TabControl Grid.Row="2" Margin="0,8,0,20"
                    Style="{StaticResource AppTabControlStyle}">

            <!-- Extract -->
            <TabItem Header="Extract" Style="{StaticResource AppTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Extract a region to a new file." Foreground="#616161"
                                   FontSize="13" Margin="0,0,0,14"/>
                        <TextBlock Text="OFFSET  (0x… or decimal)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtExtractOffset" Width="200" HorizontalAlignment="Left"
                                 Text="0x0000" Margin="0,0,0,10"/>
                        <TextBlock Text="SIZE  (0 = to end of file)" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="txtExtractSize" Width="140" Text="0"/>
                            <ComboBox x:Name="cboExtractUnit" Width="80" Margin="8,0,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Bytes"/>
                                <ComboBoxItem Content="KB"/>
                                <ComboBoxItem Content="MB"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="OUTPUT FILE" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="400"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtExtractOut" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse…" Width="90"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="BtnExtractOut_Click"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Extract Region" Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,0" Height="36" Click="BtnExtract_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="txtExtractStatus" Margin="0,10,0,0" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Insert -->
            <TabItem Header="Insert" Style="{StaticResource AppTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Insert bytes at an offset (shifts subsequent data down)."
                                   Foreground="#616161" FontSize="13" Margin="0,0,0,14"/>
                        <TextBlock Text="OFFSET  (0x… or decimal)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtInsertOffset" Width="200" HorizontalAlignment="Left"
                                 Text="0x0000" Margin="0,0,0,10"/>
                        <TextBlock Text="DATA TO INSERT  (hex, e.g. DE AD BE EF)"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtInsertData" Width="420" HorizontalAlignment="Left"
                                 Text="00 00 00 00" Margin="0,0,0,10" FontFamily="Consolas"/>
                        <TextBlock Text="OUTPUT FILE" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="400"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtInsertOut" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse…" Width="90"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="BtnInsertOut_Click"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Insert Data" Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,0" Height="36" Click="BtnInsert_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="txtInsertStatus" Margin="0,10,0,0" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Delete -->
            <TabItem Header="Delete Region" Style="{StaticResource AppTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Remove a range of bytes (shifts subsequent data up)."
                                   Foreground="#616161" FontSize="13" Margin="0,0,0,14"/>
                        <TextBlock Text="OFFSET  (0x… or decimal)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtDeleteOffset" Width="200" HorizontalAlignment="Left"
                                 Text="0x0000" Margin="0,0,0,10"/>
                        <TextBlock Text="SIZE  (bytes to delete)" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="txtDeleteSize" Width="140" Text="16"/>
                            <ComboBox x:Name="cboDeleteUnit" Width="80" Margin="8,0,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Bytes"/>
                                <ComboBoxItem Content="KB"/>
                                <ComboBoxItem Content="MB"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="OUTPUT FILE" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="400"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtDeleteOut" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse…" Width="90"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="BtnDeleteOut_Click"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Delete Region" Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,0" Height="36" Click="BtnDelete_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="txtDeleteStatus" Margin="0,10,0,0" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Overwrite -->
            <TabItem Header="Overwrite" Style="{StaticResource AppTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Fill a region with zeros, a specific byte, a hex pattern, or random data."
                                   Foreground="#616161" FontSize="13" Margin="0,0,0,14"/>
                        <TextBlock Text="OFFSET  (0x… or decimal)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtOvrOffset" Width="200" HorizontalAlignment="Left"
                                 Text="0x0000" Margin="0,0,0,10"/>
                        <TextBlock Text="SIZE" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="txtOvrSize" Width="140" Text="16"/>
                            <ComboBox x:Name="cboOvrUnit" Width="80" Margin="8,0,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Bytes"/>
                                <ComboBoxItem Content="KB"/>
                                <ComboBoxItem Content="MB"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="FILL MODE" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="cboOvrFill" Width="220" HorizontalAlignment="Left"
                                  SelectionChanged="CboOvrFill_Changed" Margin="0,0,0,10">
                            <ComboBoxItem Content="All Zeros  (0x00)" IsSelected="True"/>
                            <ComboBoxItem Content="Specific Byte"/>
                            <ComboBoxItem Content="Hex Pattern"/>
                            <ComboBoxItem Content="Random Data"/>
                        </ComboBox>
                        <StackPanel x:Name="panelOvrByte" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock Text="BYTE VALUE  (hex)" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtOvrByte" Width="120" HorizontalAlignment="Left" Text="FF"/>
                        </StackPanel>
                        <StackPanel x:Name="panelOvrPat" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock Text="HEX PATTERN" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtOvrPat" Width="360" HorizontalAlignment="Left"
                                     Text="DE AD BE EF" FontFamily="Consolas"/>
                        </StackPanel>
                        <TextBlock Text="OUTPUT FILE" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="400"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtOvrOut" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse…" Width="90"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="BtnOvrOut_Click"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Overwrite Region" Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,0" Height="36" Click="BtnOverwrite_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="txtOvrStatus" Margin="0,10,0,0" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Truncate -->
            <TabItem Header="Truncate" Style="{StaticResource AppTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Cut the file to a specified size (discard trailing bytes)."
                                   Foreground="#616161" FontSize="13" Margin="0,0,0,14"/>
                        <TextBlock Text="NEW SIZE" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="txtTruncSize" Width="140" Text="1024"/>
                            <ComboBox x:Name="cboTruncUnit" Width="80" Margin="8,0,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Bytes"/>
                                <ComboBoxItem Content="KB"/>
                                <ComboBoxItem Content="MB"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="OUTPUT FILE" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="400"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtTruncOut" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse…" Width="90"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="BtnTruncOut_Click"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Truncate File" Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,0" Height="36" Click="BtnTruncate_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTruncStatus" Margin="0,10,0,0" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

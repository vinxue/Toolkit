<UserControl x:Class="FileForge.Views.HexView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True" Drop="View_Drop" DragOver="View_DragOver">
    <DockPanel>

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0">
            <TextBlock Text="Hex Viewer" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Full-file binary view with byte selection and hex/string search. Supports files of any size."
                       Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <!-- File open toolbar -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,6"
                Background="White" BorderBrush="#E8ECEF" BorderThickness="1"
                CornerRadius="8" Padding="12,7"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="520"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtInput" Grid.Column="0" Margin="0,0,8,0"
                         ToolTip="File path — or drag a file onto the window"/>
                <Button Grid.Column="1" Content="Open…"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="14,0" Click="BtnOpen_Click"/>
                <Rectangle Grid.Column="2" Width="1" Fill="#E0E0E0" Margin="12,4"/>
                <TextBlock Grid.Column="3" Text="Go to offset:"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           FontSize="13" Foreground="#7F8C8D"/>
                <TextBox x:Name="txtJumpOffset" Grid.Column="4" Text="0x00000000"
                         FontFamily="Consolas"
                         KeyDown="TxtJumpOffset_KeyDown"
                         ToolTip="Enter a hex (0x…) or decimal offset, then press Enter or click Go"/>
                <Button Grid.Column="5" Content="Go"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="16,0" Margin="6,0,0,0" Click="BtnJump_Click"/>
            </Grid>
        </Border>

        <!-- Search toolbar -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,6"
                Background="#F4F6F8" BorderBrush="#E8ECEF" BorderThickness="1"
                CornerRadius="8" Padding="12,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*" MaxWidth="300"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search:" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontSize="13" Foreground="#7F8C8D"/>
                <ComboBox Grid.Column="1" x:Name="cboSearchMode" Margin="0,0,8,0">
                    <ComboBoxItem Content="Hex"    IsSelected="True"/>
                    <ComboBoxItem Content="String"/>
                </ComboBox>
                <TextBox x:Name="txtSearchQuery" Grid.Column="2" Margin="0,0,8,0"
                         FontFamily="Consolas"
                         KeyDown="TxtSearchQuery_KeyDown"
                         ToolTip="Hex: DE AD BE EF  or  DE??BE??    String: any text&#x0a;Press Enter / Shift+Enter to find next / previous"/>
                <Button Grid.Column="3" Content="Find Next"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="14,0" Margin="0,0,6,0" Click="BtnFindNext_Click"
                        ToolTip="Find next match  (Enter)"/>
                <Button Grid.Column="4" Content="Find Prev"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="14,0" Margin="0,0,6,0" Click="BtnFindPrev_Click"
                        ToolTip="Find previous match  (Shift+Enter)"/>
                <Button Grid.Column="5" Content="Clear"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,0" Click="BtnClearSearch_Click"/>
                <TextBlock Grid.Column="6" x:Name="txtSearchStatus"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           FontSize="12" Foreground="#7F8C8D"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#FAFAFA"
                BorderBrush="#E8ECEF" BorderThickness="0,1,0,0" Padding="16,5">
            <TextBlock x:Name="txtStatus" FontSize="12" Foreground="#7F8C8D"/>
        </Border>

        <!-- Hex panel + scrollbar -->
        <Border Margin="0,0,0,10"
                BorderBrush="#E8ECEF" BorderThickness="1"
                CornerRadius="8" ClipToBounds="True"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                </Grid.ColumnDefinitions>
                <!-- HexPanel inserted here from code-behind -->
                <Border x:Name="panelHost" Grid.Column="0" Background="White"/>
                <ScrollBar x:Name="hexScrollBar" Grid.Column="1"
                           Orientation="Vertical"
                           Background="#F8F8F8"
                           Minimum="0" Maximum="1000" Value="0"
                           SmallChange="3" LargeChange="40">
                    <ScrollBar.Style>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="Transparent" Margin="0,4,0,4">
                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Command="ScrollBar.LineUpCommand" Height="0" MinHeight="0" Opacity="0" Focusable="False" IsTabStop="False"/>
                                                </Track.DecreaseRepeatButton>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Command="ScrollBar.LineDownCommand" Height="0" MinHeight="0" Opacity="0" Focusable="False" IsTabStop="False"/>
                                                </Track.IncreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb MinHeight="44">
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border x:Name="bd" Background="#BABBBE" CornerRadius="0" Margin="2,1"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#888"/></Trigger>
                                                                    <Trigger Property="IsDragging"  Value="True"><Setter TargetName="bd" Property="Background" Value="#555"/></Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ScrollBar.Style>
                </ScrollBar>
            </Grid>
        </Border>

    </DockPanel>
</UserControl>

<UserControl x:Class="FileForge.Views.GenerateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FileForge.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,20">

            <TextBlock Text="Generate File" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Create a new binary file of a specified size filled with chosen data."
                       Style="{StaticResource SectionSubtitleStyle}"/>

            <!-- File Size -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="FILE SIZE" Style="{StaticResource FieldLabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBox x:Name="txtSize" Width="160" Text="512"
                                 TextChanged="SizeInput_Changed"/>
                        <ComboBox x:Name="cboUnit" Width="80" Margin="8,0,0,0" SelectedIndex="0"
                                  SelectionChanged="SizeInput_Changed">
                            <ComboBoxItem Content="Bytes"/>
                            <ComboBoxItem Content="KB"/>
                            <ComboBoxItem Content="MB"/>
                            <ComboBoxItem Content="GB"/>
                        </ComboBox>
                        <TextBlock x:Name="txtSizeHint" Foreground="#0078D4" FontSize="12"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Fill Content -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="FILL CONTENT" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="cboFillMode" Width="260" HorizontalAlignment="Left"
                              SelectionChanged="CboFillMode_SelectionChanged">
                        <ComboBoxItem Content="All Zeros  (0x00)" IsSelected="True"/>
                        <ComboBoxItem Content="Specific Byte"/>
                        <ComboBoxItem Content="Hex Pattern  (repeating)"/>
                        <ComboBoxItem Content="Random Data"/>
                    </ComboBox>
                    <StackPanel x:Name="panelSpecByte" Visibility="Collapsed" Margin="0,12,0,0">
                        <TextBlock Text="BYTE VALUE  (hex, e.g. FF)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtSpecByte" Width="120" HorizontalAlignment="Left" Text="FF"/>
                    </StackPanel>
                    <StackPanel x:Name="panelHexPat" Visibility="Collapsed" Margin="0,12,0,0">
                        <TextBlock Text="HEX PATTERN  (e.g. DE AD BE EF)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtHexPat" Width="360" HorizontalAlignment="Left" Text="DE AD BE EF"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output File -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="OUTPUT FILE" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtOutput" Grid.Column="0" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Browse…" Width="90"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnBrowseOutput_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnExecute" Content="Generate" Width="120" Height="36"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="BtnExecute_Click"/>
            </StackPanel>

            <local:StatusBanner x:Name="statusBanner" Margin="0,10,0,20"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

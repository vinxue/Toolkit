<UserControl x:Class="FileForge.Views.SplitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FileForge.Views"
             AllowDrop="True" Drop="View_Drop" DragOver="View_DragOver">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,20">

                <TextBlock Text="Split File" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock Text="Cut a file into parts by chunk size, size list, or byte offsets - or extract / split log lines by count, range, or even N-line chunks."
                           Style="{StaticResource SectionSubtitleStyle}"/>

                <!-- Source File -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="SOURCE FILE" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtInput" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse…" Width="90"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="BtnBrowseInput_Click"/>
                        </Grid>
                        <TextBlock x:Name="txtInputInfo" Foreground="#616161" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Split Mode -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="SPLIT MODE" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <RadioButton x:Name="rdoBySize" Content="By chunk size"
                                         GroupName="SplitMode" IsChecked="True"
                                         Checked="SplitMode_Changed"/>
                            <RadioButton x:Name="rdoBySizeList" Content="By size list"
                                         GroupName="SplitMode"
                                         Checked="SplitMode_Changed"/>
                            <RadioButton x:Name="rdoByOffset" Content="By offsets"
                                         GroupName="SplitMode"
                                         Checked="SplitMode_Changed"/>
                            <RadioButton x:Name="rdoByLines" Content="By lines (Text)"
                                         GroupName="SplitMode"
                                         Checked="SplitMode_Changed"/>
                        </StackPanel>

                        <!-- By chunk size panel -->
                        <StackPanel x:Name="panelBySize">
                            <TextBlock Text="CHUNK SIZE" Style="{StaticResource FieldLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtChunkSize" Width="140" Text="1024"/>
                                <ComboBox x:Name="cboChunkUnit" Width="80" Margin="8,0,0,0" SelectedIndex="1">
                                    <ComboBoxItem Content="Bytes"/>
                                    <ComboBoxItem Content="KB"/>
                                    <ComboBoxItem Content="MB"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>

                        <!-- By size list panel -->
                        <StackPanel x:Name="panelBySizeList" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource FieldLabelStyle}"
                                       Text="PART SIZE LIST  (parts created in order; remaining bytes → last file)"/>
                            <!-- Size entries list -->
                            <Border MinHeight="68" MaxHeight="170" Margin="0,0,0,8"
                                    BorderBrush="#D5D8DC" BorderThickness="1" CornerRadius="5"
                                    Background="#FDFEFE" SnapsToDevicePixels="True">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="2">
                                    <ListBox x:Name="lstSizes" BorderThickness="0"
                                             Background="Transparent"
                                             FontFamily="Consolas" FontSize="12"
                                             SelectionMode="Single"
                                             VirtualizingStackPanel.IsVirtualizing="False">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="8,4"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </ScrollViewer>
                            </Border>
                            <!-- Add / remove row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBox x:Name="txtSizeEntry" Width="110" Text="512"
                                         ToolTip="Enter a size value"
                                         KeyDown="TxtSizeEntry_KeyDown"/>
                                <ComboBox x:Name="cboSizeEntryUnit" Width="80" Margin="6,0,0,0" SelectedIndex="1">
                                    <ComboBoxItem Content="Bytes"/>
                                    <ComboBoxItem Content="KB"/>
                                    <ComboBoxItem Content="MB"/>
                                </ComboBox>
                                <Button Content="+ Add" Padding="14,0" Height="34" Margin="8,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="BtnAddSize_Click"/>
                                <Button Content="Remove" Padding="10,0" Height="34" Margin="6,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="BtnRemoveSize_Click"/>
                                <Button Content="Clear" Padding="10,0" Height="34" Margin="6,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="BtnClearSizes_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="txtSizeListSummary"
                                       Foreground="#7F8C8D" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- By offset panel -->
                        <StackPanel x:Name="panelByOffset" Visibility="Collapsed">
                            <TextBlock Text="OFFSETS  (one per line, hex 0x… or decimal)"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtOffsets" Height="100" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="13"
                                     Text="0x00010000&#x0a;0x00020000"/>
                        </StackPanel>

                        <!-- By lines panel -->
                        <StackPanel x:Name="panelByLines" Visibility="Collapsed">
                            <TextBlock Text="LINE EXTRACTION MODE" Style="{StaticResource FieldLabelStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <RadioButton x:Name="rdoFirstLines" Content="First N lines"
                                             GroupName="LineMode" IsChecked="True"
                                             Checked="LineMode_Changed" Margin="0,0,20,0"/>
                                <RadioButton x:Name="rdoLastLines" Content="Last N lines"
                                             GroupName="LineMode"
                                             Checked="LineMode_Changed" Margin="0,0,20,0"/>
                                <RadioButton x:Name="rdoLineRange" Content="Line range"
                                             GroupName="LineMode"
                                             Checked="LineMode_Changed" Margin="0,0,20,0"/>
                                <RadioButton x:Name="rdoSplitLines" Content="Split every N lines"
                                             GroupName="LineMode"
                                             Checked="LineMode_Changed"/>
                            </StackPanel>

                            <!-- N-lines sub-panel (First / Last / Split every N) -->
                            <StackPanel x:Name="panelNLines">
                                <TextBlock x:Name="txtLineCountLabel" Text="LINE COUNT"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="txtLineCount" Width="160"
                                         HorizontalAlignment="Left" Text="1000"/>
                            </StackPanel>

                            <!-- Line-range sub-panel -->
                            <StackPanel x:Name="panelLineRange" Visibility="Collapsed">
                                <TextBlock Text="LINE RANGE  (1-based, inclusive)"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="From line" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBox x:Name="txtFromLine" Width="120" Text="1"/>
                                    <TextBlock Text="to line" VerticalAlignment="Center"
                                               Margin="12,0,8,0"/>
                                    <TextBox x:Name="txtToLine" Width="120" Text="1000"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Info / line-count hint -->
                            <TextBlock x:Name="txtLineInfo" Foreground="#7F8C8D"
                                       FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Output Settings -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="OUTPUT DIRECTORY" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtOutputDir" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse…" Width="90"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="BtnBrowseDir_Click"/>
                        </Grid>

                        <TextBlock Text="NAMING PATTERN  ({name} = original name, {n} = part number, {ext} = extension)"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtNamePattern" Width="320" HorizontalAlignment="Left"
                                 Text="{}{name}_part{n}.{ext}"/>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Execute" Width="120" Height="36"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="BtnExecute_Click"/>
                </StackPanel>

                <local:StatusBanner x:Name="statusBanner" Margin="0,10,0,6"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Results -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                MaxHeight="200" Visibility="{Binding ElementName=lstResults, Path=Visibility}">
            <DockPanel Margin="0,8">
                <TextBlock DockPanel.Dock="Top" Text="OUTPUT FILES" Style="{StaticResource FieldLabelStyle}"
                           Margin="0,4,0,6"/>
                <ListBox x:Name="lstResults" Visibility="Collapsed"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         BorderThickness="0" Background="Transparent"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
